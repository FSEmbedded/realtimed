-    status = upwr_xcp_set_rtd_apd_llwu(APD_DOMAIN, (uint32_t)true, UPOWER_Callback);
+    status = upwr_xcp_set_rtd_apd_llwu(APD_DOMAIN, (uint32_t)true, NULL);
     if (status == 0)
     {
